{
  "name": "react-native-auto-shimmer",
  "version": "0.0.3",
  "description": "Auto-generated skeleton loading screens for React Native",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-auto-shimmer-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "inspect": "WITH_ROZENITE=true yarn example start",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "shimmer",
    "skeleton",
    "loading",
    "screen",
    "ui",
    "component",
    "react",
    "native",
    "react-native",
    "react-native-auto-shimmer",
    "rozenite-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/numandev1/react-native-auto-shimmer.git"
  },
  "author": "Numan <muhammadnuman70@gmail.com> (https://github.com/numandev1)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/numandev1/react-native-auto-shimmer/issues"
  },
  "homepage": "https://github.com/numandev1/react-native-auto-shimmer#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@react-native/babel-preset": "0.83.4",
    "@react-native/eslint-config": "0.83.4",
    "@types/react": "^19.2.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-builder-bob": "^0.41.0",
    "release-it": "^19.2.4",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example",
    "packages/*"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint"
    ],
    "version": "0.59.0"
  }
}
