{
  "name": "@react-native-auto-shimmer/rozenite-plugin",
  "version": "0.1.0",
  "description": "Rozenite DevTools plugin for react-native-auto-shimmer — visual skeleton inspector",
  "type": "module",
  "main": "./dist/react-native.cjs",
  "module": "./dist/react-native.js",
  "types": "./dist/react-native.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-native.js",
      "require": "./dist/react-native.cjs",
      "types": "./dist/react-native.d.ts"
    },
    "./metro": {
      "require": "./metro.cjs",
      "default": "./metro.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "rozenite dev",
    "build": "rozenite build"
  },
  "keywords": [
    "react-native",
    "skeleton",
    "devtools",
    "rozenite"
  ],
  "license": "MIT",
  "dependencies": {
    "@rozenite/plugin-bridge": "^1.2.0"
  },
  "devDependencies": {
    "@rozenite/vite-plugin": "^1.2.0",
    "@types/react": "~19.1.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.2",
    "rozenite": "^1.2.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  }
}
